# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in real values.
# NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── TRADESTATION API (existing — used by both dashboard and bot) ─────────────

# OAuth2 Client ID from your TradeStation developer app
TRADESTATION_CLIENT_ID=your_client_id_here

# OAuth2 Client Secret from your TradeStation developer app
TRADESTATION_CLIENT_SECRET=your_client_secret_here

# Refresh token obtained from the OAuth2 authorization flow
# Run: python get_ts_token.py to generate this
TRADESTATION_REFRESH_TOKEN=your_refresh_token_here

# ── TRADESTATION ACCOUNT (NEW — required for order placement) ────────────────

# Your TradeStation brokerage account ID (the numeric account number,
# e.g. "123456789"). Find it in the TradeStation platform under Account Info.
TRADESTATION_ACCOUNT_ID=your_account_id_here

# Optional: override the default continuous-contract symbols used for orders.
# Useful if market orders reject with @ES; set the front-month instead.
# Format: comma-separated KEY=VALUE pairs, e.g. "ES=@ESM25,NQ=@NQM25"
# Leave blank to use the defaults from bot/config_bot.py.
TRADESTATION_SYMBOL_OVERRIDE=

# ── OPENAI API (for news sentiment scoring) ───────────────────────────────────

# Your OpenAI API key (starts with sk-proj-...)
# Create one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_key_here

# Model to use for sentiment scoring (default is gpt-4o-mini for low cost)
# Options: gpt-4o-mini, gpt-4o, gpt-4-turbo
OPENAI_MODEL=gpt-4o-mini

# ── TRADIER API (for 0DTE gamma exposure on option chains) ────────────────────

# Your Tradier API access token
# Sign up at: https://developer.tradier.com
# Find your token at: https://developer.tradier.com/user/profile
TRADIER_API_KEY=your_tradier_api_key_here

# Base URL — use sandbox for testing, live for production
# Sandbox : https://sandbox.tradier.com/v1
# Live    : https://api.tradier.com/v1
TRADIER_BASE_URL=https://api.tradier.com/v1

# ── TELEGRAM BOT (for trade alerts and /approve / /reject replies) ────────────

# Bot token obtained from @BotFather on Telegram
# Steps: open Telegram → search @BotFather → /newbot → copy the token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Your personal Telegram chat ID (or a group chat ID).
# To find yours: send a message to @userinfobot on Telegram.
# For a group: add the bot to the group, send a message, check
#   https://api.telegram.org/bot<TOKEN>/getUpdates for "chat"."id"
TELEGRAM_CHAT_ID=your_chat_id_here
